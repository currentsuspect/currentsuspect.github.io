---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Dylan Makori — currentsuspect.me"
  description="Dylan Makori — Founder, Builder, Producer. Nairobi. Building tools, making music, and thinking out loud."
>
  <section class="hero">
    <div class="hero-prompt">~/home/dylan $</div>
    <h1>
      Dylan Makori.<br />
      <span class="hero-tagline"><span>Founder. Builder. Producer.</span><span class="cursor"></span></span>
    </h1>
    <p class="hero-desc">
      Building tools, making music, and thinking out loud.<br />
      Based in Nairobi. Running Aestra and PlainSight Digital.<br />
      Going by currentsuspect everywhere else.
    </p>
    <div class="tags">
      <span class="tag">C++</span>
      <span class="tag">audio engineering</span>
      <span class="tag">web agency</span>
      <span class="tag">Nairobi</span>
      <span class="tag">underground music</span>
      <span class="tag">systems thinking</span>
    </div>
  </section>
</BaseLayout>
