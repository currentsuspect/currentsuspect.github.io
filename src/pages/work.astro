---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Work — currentsuspect.me"
  description="What Dylan Makori is building."
>
  <section class="section" id="work">
    <div class="section-label">work</div>
    <h2>What I'm building</h2>
    <div class="cards">
      <a class="card" href="https://aestra.app" target="_blank" rel="noopener">
        <div class="card-icon">
          <svg viewBox="0 0 24 24"><polyline points="2 12 5 12"/><polyline points="7 6 7 18"/><polyline points="10 9 10 15"/><polyline points="13 4 13 20"/><polyline points="16 8 16 16"/><polyline points="19 10 19 14"/><polyline points="22 12 22 12"/></svg>
        </div>
        <div class="card-title">Aestra DAW</div>
        <div class="card-sub">Free, source-available DAW for beatmakers on low-end hardware. Built from scratch in C++17.</div>
        <div class="card-ext">aestra.app ↗</div>
      </a>
      <a class="card" href="https://plainsightdigital.dev" target="_blank" rel="noopener">
        <div class="card-icon">
          <svg viewBox="0 0 24 24"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>
        </div>
        <div class="card-title">PlainSight Digital</div>
        <div class="card-sub">Web agency. High-converting sites for Kenyan businesses. I don't build websites — I build business tools.</div>
        <div class="card-ext">plainsightdigital.dev ↗</div>
      </a>
    </div>
  </section>
</BaseLayout>
