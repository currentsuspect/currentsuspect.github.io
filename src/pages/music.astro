---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Music — currentsuspect.me"
  description="currentsuspect — music by Dylan Makori."
>
  <section class="section" id="music">
    <div class="section-label">music</div>
    <h2>currentsuspect</h2>
    <div class="cards" style="margin-top: 1.25rem;">
      <div class="card">
        <div class="card-icon">
          <svg viewBox="0 0 24 24"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="3"/></svg>
        </div>
        <div class="card-title">Echoes and Euphoria</div>
        <div class="card-sub">Forthcoming album.</div>
        <div class="card-ext">coming soon</div>
      </div>
      <div class="card">
        <div class="card-icon">
          <svg viewBox="0 0 24 24"><path d="M9 18V5l12-2v13"/><circle cx="6" cy="18" r="3"/><circle cx="18" cy="16" r="3"/></svg>
        </div>
        <div class="card-title">Archive</div>
        <div class="card-sub">Earlier work, experiments, beats.</div>
        <div class="card-ext">soundcloud ↗</div>
      </div>
    </div>
  </section>
</BaseLayout>
