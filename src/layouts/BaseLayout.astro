---
import '../styles/global.css';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import ThemeToggle from '../components/ThemeToggle.astro';

interface Props {
  title: string;
  description: string;
  ogType?: 'website' | 'article';
  publishedTime?: string;
  author?: string;
}

const {
  title,
  description,
  ogType = 'website',
  publishedTime,
  author = 'Dylan Makori',
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const fullTitle = title.includes('currentsuspect.me')
  ? title
  : `${title} — currentsuspect.me`;
const pathname = Astro.url.pathname;
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta property="og:title" content={fullTitle} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={canonical} />
  <meta property="og:type" content={ogType} />
  {publishedTime && <meta property="article:published_time" content={publishedTime} />}
  {ogType === 'article' && <meta property="article:author" content={author} />}
  <link rel="canonical" href={canonical} />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{fullTitle}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link
    href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&display=swap"
    rel="stylesheet"
  />
  <link
    rel="alternate"
    type="application/rss+xml"
    title="currentsuspect.me — writing"
    href="/rss.xml"
  />
  <script is:inline>
    (function () {
      if (localStorage.getItem('theme') === 'light') {
        document.documentElement.setAttribute('data-theme', 'light');
      }
    })();
  </script>
</head>
<body>
  <Nav pathname={pathname}>
    <ThemeToggle slot="theme-toggle" />
  </Nav>

  <slot />

  <Footer />

  <script is:inline>
    function toggleTheme() {
      var h = document.documentElement;
      if (h.getAttribute('data-theme') === 'light') {
        h.removeAttribute('data-theme');
        localStorage.setItem('theme', 'dark');
      } else {
        h.setAttribute('data-theme', 'light');
        localStorage.setItem('theme', 'light');
      }
    }
  </script>
</body>
</html>
